# ─── Supabase ─────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── LiveKit (live streaming) ─────────────────────────────
# Get from: https://cloud.livekit.io/projects
# Used by: lib/livekit.ts (live streaming rooms)
EXPO_PUBLIC_LIVEKIT_URL=wss://YOUR_INSTANCE.livekit.cloud

# ─── Gemini (AI hairstyle tryon) ──────────────────────────
# Get from: https://aistudio.google.com/apikey
# Used by: hooks/useHairstyleTryon.ts (AI hairstyle generation in tryon screen)
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_KEY

# ─── Mapbox (discover map) ────────────────────────────────
# Public token (pk....) — renders the map at runtime.
# Get from: https://account.mapbox.com/access-tokens
# Used by: lib/mapbox.ts → app/(tabs)/discover.tsx
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_PUBLIC_TOKEN
# Optional: custom Mapbox Studio style (mapbox://styles/<user>/<style-id>).
# Falls back to the standard light style when unset.
EXPO_PUBLIC_MAPBOX_STYLE_URL=
# Secret download token (sk.... with DOWNLOADS:READ scope) — build time only.
# Required by the @rnmapbox/maps config plugin to fetch the native SDK.
# Do NOT prefix with EXPO_PUBLIC_ (it must stay out of the JS bundle).
RNMAPBOX_DOWNLOAD_TOKEN=sk.YOUR_DOWNLOAD_TOKEN

# ─── nopCommerce storefront API (marketplace catalogue) ───
# Live catalogue source for the store section (browse/search/PDP/filters).
# No API key needed for the catalogue — a guest token is auto-minted.
# Used by: lib/nop-client.ts
EXPO_PUBLIC_NOP_BASE_URL=https://barber-staging.ecomdigitalservers.ro
