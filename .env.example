# ─── Supabase ─────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── LiveKit (live streaming) ─────────────────────────────
# Get from: https://cloud.livekit.io/projects
# Used by: lib/livekit.ts (live streaming rooms)
EXPO_PUBLIC_LIVEKIT_URL=wss://YOUR_INSTANCE.livekit.cloud

# ─── Gemini (AI hairstyle tryon) ──────────────────────────
# Get from: https://aistudio.google.com/apikey
# Used by: hooks/useHairstyleTryon.ts (AI hairstyle generation in tryon screen)
EXPO_PUBLIC_GEMINI_API_KEY=YOUR_GEMINI_KEY
